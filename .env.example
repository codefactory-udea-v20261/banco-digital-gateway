# Banco Digital Gateway - Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_PROFILE=local
APP_PORT=8000

# Eureka
EUREKA_URL=http://localhost:8761/eureka/

# JWT
JWT_SECRET=your_base64_encoded_256bit_secret_here
JWT_EXPIRATION_MS=3600000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Vault
VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
